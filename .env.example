NODE_ENV=development
APP_URL=http://localhost:3000
APP_NAME=Telegramplay
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_BOT_USERNAME=replace-me
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=replace-me
NEXT_PUBLIC_APP_THEME=graphite-racer
NEXT_PUBLIC_GAME_TITLE_SLUG=racer-poc
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@[host]:6543/postgres?sslmode=require
SUPABASE_URL=https://project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=replace-me
SUPABASE_SECRET_KEY=replace-me
SESSION_COOKIE_NAME=tg_session
SESSION_TTL_HOURS=24
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=300
ALLOW_DEV_AUTH=true
NEXT_PUBLIC_DEV_INIT_DATA=
DEV_AUTH_SECRET=replace-me
OPS_ADMIN_TELEGRAM_IDS=123456789
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
LOG_LEVEL=info
DEPLOYMENT_VERSION=dev
VERCEL_GIT_COMMIT_SHA=local
USE_MEMORY_STORE=true
